  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cddcc1e9-7bc5-4ead-b9aa-8368095d714a",
   "metadata": {},
   "outputs": [],
   "source": [
    "if __name__ == \"__main__\":\n",
    "    num_shots = 10000\n",
    "    run_as_batched = True\n",
    "    print_output = False\n",
    "    osd_method = 3 # 0 is off, 1 OSD-0, 3 is a higher order OSD\n",
